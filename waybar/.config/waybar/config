{
    "layer": "top",
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-right":
    ["tray",
    "custom/mullvad",
    "wireplumber", 
    "mpd",
    "cpu", 
    "custom/bitcoin", 
    "custom/weather", 
    "battery", 
    "network",
    "wifi",
    "custom/birthday-clock"],

    "hyprland/window": {
        "max-length": 50
    },
    "tray": {
    },
    "custom/mullvad": {
    	"exec": "~/.local/bin/vpn-status",
	"interval": 10,
	"return-type": "text",
	"tooltip": true,
	"on-click": "kitty -e sh -c 'mullvad status -v; bash'",
	"on-click-right": "kitty -e 'vpn-connect'"
    },
    "wireplumber": {
    	"format": "{volume}% ",
    	"format-muted": "Muted ",
	"scroll-step": 5,
	"on-click": "kitty -e alsamixer",
	"on-click-right": "sh -c 'exec qpwgraph >/dev/null 2>&1 &'"
    },
    "mpd": {
        "format": "{stateIcon} {elapsedTime:%M:%S}/{totalTime:%M:%S}",
        "tooltip": true,
        "tooltip-format": "{artist} - {album} - {title}",
        "interval": 5,
        "state-icons": {
            "playing": "",
            "paused": ""
        },
        "on-click": "mpc toggle",
	"on-click-right": "kitty -e rmpc"
    },
    "cpu": {
        "format": "  {usage}%",
        "tooltip": true,
        "tooltip-format": "CPU: {usage}%",
	"on-click": "kitty -e btop"
    },
    "custom/bitcoin": {
        "exec": "~/.local/bin/bitcoin",
        "interval": 1800,
	"return-type": "json",
        "format": " {} ",
	"on-click": "kitty -e bash -c 'curl rate.sx/btc@30D; echo; read -p \"Press Enter to close...\"'",
	"on-click-right": "kitty -e bash -c 'curl rate.sx; echo; read -p \"Press Enter to close...\"'"
    },
    "custom/weather": {
        "exec": "~/.local/bin/weather",
        "interval": 1800,
	"return-type": "json",
        "format": " {} ",
	"on-click": "kitty -e bash -c 'LOC=$(cat \"$HOME/.location\"); curl wttr.in/$LOC; echo; read -p \"Press Enter to close...\"'",
	"on-click-middle": "~/.local/bin/sunrise-sunset",
	"on-click-right": "kitty -e bash -c 'curl wttr.in/moon; echo; read -p \"Press Enter to close...\"'"
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["", "", "", "", ""]
    },
    "network": {
	"format": "{icon}",
	"format-wifi": "",
	"format-ethernet": "",
	"format-disconnected": "",
	"tooltip-format-wifi": "{essid} ",
	"tooltip-format-ethernet": "Connected ",
	"tooltip-format-disconnected": "Disconnected",
	"max-length": 50,
	"on-click": "nm-connection-editor"
    },
    "custom/birthday-clock": {
        "exec": "bash -c 'BDAY=$(<\"$HOME/.birthday\"); echo \"{\\\"text\\\": \\\"$(date +\"%a, %d. %b %H:%M \")\\\", \\\"tooltip\\\": \\\"$( [ $(date +%m-%d) = \"$BDAY\" ] && echo is birthday || echo not birthday )\\\"}\"'",
        "interval": 60,
        "return-type": "json",
	"on-click": "kitty -e calcurse"
    }
}
